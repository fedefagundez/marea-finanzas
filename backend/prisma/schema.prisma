generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  ingresos            Ingreso[]
  gastos              Gasto[]
  metas               Meta[]
  miembros            MiembroHogar[]
  categorias          Categoria[]
  passwordResetTokens PasswordResetToken[]

  @@map("usuarios")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  usuarioId String @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Hogar {
  id        String   @id @default(uuid())
  nombre    String
  createdAt DateTime @default(now()) @map("created_at")
  tokenInvitacion String? @unique @map("token_invitacion")

  miembros   MiembroHogar[]
  ingresos   Ingreso[]
  gastos     Gasto[]
  metas      Meta[]
  tarjetas   TarjetaCredito[]
  categorias Categoria[]

  @@map("hogares")
}

model MiembroHogar {
  id       String   @id @default(uuid())
  rol      String   @default("MIEMBRO")
  joinedAt DateTime @default(now()) @map("joined_at")

  usuarioId String @map("usuario_id")
  hogarId   String @map("hogar_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  hogar   Hogar   @relation(fields: [hogarId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, hogarId])
  @@map("miembros_hogar")
}

model TarjetaCredito {
  id       String @id @default(uuid())
  nombre   String
  ultimo4  String @map("ultimo_4")
  hogarId  String @map("hogar_id")

  hogar    Hogar    @relation(fields: [hogarId], references: [id], onDelete: Cascade)
  gastos   Gasto[]

  @@map("tarjetas_credito")
}

model Categoria {
  id        String   @id @default(uuid())
  nombre    String
  icon      String   @default("📂")
  createdAt DateTime @default(now()) @map("created_at")

  usuarioId String? @map("usuario_id")
  hogarId   String? @map("hogar_id")

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  hogar   Hogar?   @relation(fields: [hogarId], references: [id], onDelete: Cascade)
  gastos  Gasto[]

  @@map("categorias")
}

model Ingreso {
  id          String   @id @default(uuid())
  descripcion String
  monto       Decimal
  tipo        String
  fechaInicio DateTime? @map("fecha_inicio")
  fechaFin    DateTime? @map("fecha_fin")
  createdAt   DateTime @default(now()) @map("created_at")

  hogarId   String @map("hogar_id")
  usuarioId String @map("usuario_id")

  hogar   Hogar   @relation(fields: [hogarId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("ingresos")
}

model Gasto {
  id             String   @id @default(uuid())
  descripcion    String
  monto          Decimal
  tipo           String
  fechaInicio    DateTime? @map("fecha_inicio")
  cuotasTotales  Int?     @map("cuotas_totales")
  cuotasPagadas  Int      @default(0) @map("cuotas_pagadas")
  createdAt      DateTime @default(now()) @map("created_at")

  hogarId     String  @map("hogar_id")
  usuarioId   String  @map("usuario_id")
  tarjetaId   String? @map("tarjeta_id")
  categoriaId String? @map("categoria_id")

  hogar     Hogar           @relation(fields: [hogarId], references: [id], onDelete: Cascade)
  usuario   Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tarjeta   TarjetaCredito? @relation(fields: [tarjetaId], references: [id], onDelete: SetNull)
  categoria Categoria?      @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  @@map("gastos")
}

model Meta {
  id            String   @id @default(uuid())
  nombre        String
  montoObjetivo Decimal  @map("monto_objetivo")
  montoActual   Decimal  @default(0) @map("monto_actual")
  fechaLimite   DateTime @map("fecha_limite")
  cuotaMensual  Decimal? @map("cuota_mensual")
  gastoId       String?  @map("gasto_id")
  createdAt     DateTime @default(now()) @map("created_at")

  hogarId   String @map("hogar_id")
  usuarioId String @map("usuario_id")

  hogar   Hogar   @relation(fields: [hogarId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("metas")
}
